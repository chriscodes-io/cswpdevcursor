# Pica (https://app.picaos.com)
PICA_SECRET=your_pica_secret_key
GMAIL_CONNECTION_KEY=your_gmail_connection_key
HUBSPOT_CONNECTION_KEY=your_hubspot_connection_key
SLACK_CONNECTION_KEY=your_slack_connection_key

# OpenAI — lead extraction + qualification scoring
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Gmail
GMAIL_LEADS_LABEL=Leads
GMAIL_LOOKBACK_HOURS=24
GMAIL_MAX_MESSAGES=25

# Qualification
QUALIFICATION_THRESHOLD=7

# HubSpot
HUBSPOT_PORTAL_ID=your_portal_id

# Slack (channel ID e.g. C01234567, or #sales-leads name)
SLACK_CHANNEL=#sales-leads
