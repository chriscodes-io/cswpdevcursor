# Server
PORT=3000
NODE_ENV=development
SITE_URL=http://localhost:3000

# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=reports@yourdomain.com

# Google PageSpeed Insights (optional — improves performance scores)
GOOGLE_PAGESPEED_API_KEY=

# wpaudit.pro (optional — no public API; opens in browser from frontend)
WPAUDIT_API_KEY=

# Protect dashboard API routes (Bearer token)
DASHBOARD_API_KEY=change-me-to-a-long-random-string
